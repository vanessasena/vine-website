# Supabase Configuration
# Get these values from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# AI Gateway Configuration (for AI-powered sermon formatting)
# Vercel AI Gateway: https://vercel.com/docs/ai-gateway
#   1. Go to vercel.com → your team → AI Gateway → create a gateway with an OpenAI provider
#   2. Create a Vercel API token at vercel.com → Settings → Tokens (starts with vck_)
#   3. Set AI_GATEWAY_API_KEY to that token below
# Base URL is always https://ai-gateway.vercel.sh/v1 (handled in src/lib/ai.ts)
AI_GATEWAY_API_KEY=
